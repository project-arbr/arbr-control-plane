# Arbr Control Plane — environment
# Copy to .env. Every value below has a safe default; NO key is required to start.
#
# ── PRODUCTION CHECKLIST ────────────────────────────────────────────────────
# Before deploying beyond localhost, uncomment and set these three:
#
#   ARBR_ADMIN_KEY=<node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
#   ARBR_ENCRYPTION_KEY=<same command, run again for a second value>
#   SEED_ON_BOOT=false
#
# Then add at least one provider key (OPENAI_API_KEY, ANTHROPIC_API_KEY, etc.)
# and run via Docker Compose (see docker-compose.prod.yml for loopback binding).
# ────────────────────────────────────────────────────────────────────────────
# With no provider keys, the service runs in DEMO MODE: dashboards, analytics,
# recommendations, rules and budgets all work on seeded data — only the live
# gateway path (POST /v1/chat) is disabled until you add at least one key.
#
# NOTE: routing mode (off/guardrail/AI), Require-API-keys, budgets, gateway API
# keys and the default provider/model are RUNTIME settings managed in the
# dashboard — they live in MongoDB, not here.

# --- Server ---
PORT=4100
# Interface to bind. Keep 0.0.0.0 in containers; use 127.0.0.1 on a bare VM
# behind a same-host reverse proxy (see DEPLOYMENT.md).
HOST=0.0.0.0
# Comma-separated list of origins allowed to call the API (only relevant for the
# Vite dev server; single-port mode is same-origin).
CORS_ORIGIN=http://localhost:5173

# --- Database ---
MONGO_URI=mongodb://localhost:27017/arbr-control-plane

# --- Authentication ---
# Master key for the dashboard + admin API. Unset = OPEN admin (local dev only —
# the boot log warns). REQUIRED when NODE_ENV=production (boot refuses otherwise).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ARBR_ADMIN_KEY=

# Per-source-IP rate limit on the admin API (blunts DB-hammering from an
# accidental loop or a leaked key). Default 600 req/min; rarely needs tuning.
# ARBR_ADMIN_RPM_GUARDRAIL=600

# --- Identity (F-04: accountable admin access) ---
# ARBR_ADMIN_KEY above still works as a break-glass credential in every mode
# below — it's just no longer the everyday human login path once one of
# these is configured. See docs/auth.md for full setup instructions.
#
# adminkey (default) — today's behavior, no per-user identity.
# oidc              — sign in via any OIDC provider (Okta, Auth0, Google
#                      Workspace, Keycloak, ...). Requires the four vars below.
# trusted-header    — trust an identity already verified by GCP IAP or a
#                      reverse proxy in front of arbr (see ARBR_TRUSTED_HEADER_*).
# ARBR_AUTH_MODE=adminkey

# --- OIDC (ARBR_AUTH_MODE=oidc) ---
# ARBR_OIDC_ISSUER=https://your-idp.example.com
# ARBR_OIDC_CLIENT_ID=
# ARBR_OIDC_CLIENT_SECRET=
# ARBR_OIDC_REDIRECT_URI=https://arbr.your-domain.com/api/auth/callback

# --- Trusted header (ARBR_AUTH_MODE=trusted-header) ---
# "iap" verifies GCP Identity-Aware Proxy's signed header; "proxy" trusts any
# reverse proxy that injects an identity header + a shared secret.
# ARBR_TRUSTED_HEADER_STRATEGY=proxy
# ARBR_IAP_AUDIENCE=/projects/PROJECT_NUMBER/global/backendServices/SERVICE_ID
# ARBR_PROXY_AUTH_HEADER=x-forwarded-email
# ARBR_PROXY_SECRET_HEADER=x-arbr-proxy-secret
# ARBR_PROXY_AUTH_SECRET=<node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

# How long an OIDC session stays valid before re-authentication (hours).
# ARBR_SESSION_TTL_HOURS=12

# --- Secrets ---
# Encrypts provider keys entered via the dashboard, at rest. Optional for the
# demo (an insecure dev key is used with a warning); REQUIRED when
# NODE_ENV=production (boot refuses otherwise).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ARBR_ENCRYPTION_KEY=

# --- Production ---
# docker-compose.prod.yml sets NODE_ENV=production automatically. If running the
# server without that Compose profile, set it yourself to force fail-closed boot
# (admin + encryption keys required) and reject anonymous /v1 calls.
# NODE_ENV=production

# --- Fallback scope (provider errors) ---
# same-provider (default) — retry this provider's default model only
# cross-provider          — walk remaining live providers (legacy availability mode)
# none                    — fail the request; no automatic fallback
# ARBR_FALLBACK_SCOPE=same-provider

# --- Demo data ---
# Docker only: SEED_ON_BOOT=true loads the synthetic demo dataset on container
# start. WARNING: seeding WIPES existing request records — never in production.
# (Local equivalent: npm run seed)
# SEED_ON_BOOT=false

# --- Providers (all optional) ---
# Add one or more to enable live gateway calls. Leave blank for demo mode.
# You can also add keys at runtime in the dashboard (Settings → Connections);
# env vars set here take precedence over dashboard-stored keys.
# OPENAI_API_KEY=sk-...
# To route OpenAI-provider requests through a LiteLLM proxy or another
# OpenAI-compatible endpoint, set OPENAI_BASE_URL to that endpoint:
# OPENAI_BASE_URL=http://localhost:8000
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# DEEPSEEK_API_KEY=...
# MOONSHOT_API_KEY=...
# XAI_API_KEY=...
# GROQ_API_KEY=...

# LiteLLM Proxy — front Bedrock (or any provider) through a LiteLLM instance
# while keeping openai pointed at api.openai.com. Set all three to activate.
# Register models against it via POST /api/models with { "provider": "litellm" }.
# LITELLM_BASE_URL=http://your-litellm-host:8000
# LITELLM_API_KEY=your-litellm-master-key
# LITELLM_DEFAULT_MODEL=bedrock/us.amazon.nova-lite-v1:0

# Amazon Bedrock — uses AWS credentials, not a single key.
# Provider id is "bedrock-nova". Region defaults to us-east-1 if omitted.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# Initial default provider preference (one of: openai | anthropic | gemini |
# bedrock-nova | deepseek | moonshot | xai | groq). Runtime-selectable in
# Settings → Connections, which takes precedence.
# DEFAULT_PROVIDER=

# --- Web dashboard (dev server) ---
WEB_PORT=5173
